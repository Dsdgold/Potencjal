# ─── Core ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://potencjal:potencjal@postgres:5432/potencjal
DATABASE_URL_SYNC=postgresql://potencjal:potencjal@postgres:5432/potencjal
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_SECRET=change-me-too
NEXTAUTH_URL=http://localhost:3000

# ─── Data Providers ───────────────────────────────
# MF VAT Whitelist – no key needed (public API)
VAT_API_BASE_URL=https://wl-api.mf.gov.pl

# GUS REGON/BIR1 – get key at https://api.stat.gov.pl
GUS_API_KEY=
GUS_API_URL=https://wyszukiwarkaregon.stat.gov.pl/wsBIR/UslugaBIRzewnworki.svc

# KRS – public OpenAPI
KRS_API_BASE_URL=https://api-krs.ms.gov.pl/api/krs

# CEIDG – get key at https://dane.biznes.gov.pl
CEIDG_API_KEY=
CEIDG_API_URL=https://dane.biznes.gov.pl/api/ceidg/v2

# ─── Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ─── Embedding ─────────────────────────────────────
EMBEDDING_PROVIDER=local
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ─── Encryption ────────────────────────────────────
CREDENTIALS_ENCRYPTION_KEY=change-me-use-fernet-key

# ─── Observability ─────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=
ENVIRONMENT=development

# ─── Cache TTL (seconds) ──────────────────────────
SNAPSHOT_TTL_SECONDS=86400
