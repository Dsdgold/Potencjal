[Unit]
Description=Potencjal GitHub Webhook Listener
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/potencjal/deploy
EnvironmentFile=/opt/potencjal/deploy/.env
ExecStart=/usr/bin/python3 /opt/potencjal/deploy/webhook.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
